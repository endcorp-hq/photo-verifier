{
  "name": "@photoverifier/core",
  "version": "0.1.0",
  "description": "Portable core primitives for photo verification - hashing, storage, contracts, types",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": "./dist/index.js",
    "./dist/*": "./dist/*",
    "./contracts/chain-contracts": "./dist/contracts/chain-contracts.js",
    "./contracts/api-contracts": "./dist/contracts/api-contracts.js",
    "./network/cluster-policy": "./dist/network/cluster-policy.js",
    "./hash": "./dist/hash.js",
    "./storage": "./dist/storage.js",
    "./types": "./dist/types.js"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.74"
  },
  "dependencies": {
    "@noble/hashes": "^1.5.0",
    "js-base64": "^3.7.8"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.3",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.56.1"
  }
}
