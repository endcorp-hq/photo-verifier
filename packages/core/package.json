    "expo-media-library": "*",
    "react": ">=18",
    "react-native": ">=0.74"
  },
  "dependencies": {
    "@noble/hashes": "^1.5.0",
    "js-base64": "^3.7.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.3",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.56.1"
  }
