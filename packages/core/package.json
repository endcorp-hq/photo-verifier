{
  "name": "@photoverifier/core",
  "version": "0.1.0",
  "description": "Core functionality for photo verification - hashing, camera, location, storage (free, open-source)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
