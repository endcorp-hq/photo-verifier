{
  "name": "@photoverifier/sdk",
  "version": "0.2.0",
  "description": "PhotoVerifier SDK for photo verification with blockchain anchoring",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "react-native": "src/index.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/endcorp-hq/photo-verifier.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "@solana/spl-token": "*",
    "@solana/web3.js": "*",
    "expo": ">=51",
    "expo-camera": "*",
    "expo-file-system": "~18.1.11",
    "expo-location": "*",
    "expo-media-library": "*",
    "react": ">=18",
    "react-native": ">=0.74"
  },
  "dependencies": {
    "@photoverifier/core": "workspace:*",
    "@photoverifier/blockchain": "workspace:*",
    "@noble/hashes": "^1.5.0",
    "h3-reactnative": "github:endcorp-hq/h3-reactnative#4e19a7c445e131977b6a031ecffe86dacbaa7f46",
    "js-base64": "^3.7.8"
  }
}
