{
  "name": "@endcorp/photoverifier-sdk",
  "version": "0.2.1",
  "description": "PhotoVerifier SDK for photo verification with blockchain anchoring",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "react-native": "dist/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/endcorp-hq/photo-verifier.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "peerDependencies": {
    "@solana/spl-token": "*",
    "@solana/web3.js": "*",
    "expo": ">=51",
    "expo-camera": "*",
    "expo-file-system": "~18.1.11",
    "expo-location": "*",
    "expo-media-library": "*",
    "react": ">=18",
    "react-native": ">=0.74"
  },
  "dependencies": {
    "@noble/hashes": "^1.5.0",
    "@solana/spl-account-compression": "^0.2.1",
    "h3-reactnative": "github:endcorp-hq/h3-reactnative#4e19a7c445e131977b6a031ecffe86dacbaa7f46",
    "js-base64": "^3.7.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.3",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.56.1"
  }
}
