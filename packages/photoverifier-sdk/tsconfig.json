{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@photoverifier/core-mobile/camera": ["../core-mobile/dist/camera.d.ts"],
      "@photoverifier/core-mobile/location": ["../core-mobile/dist/location.d.ts"]
    },
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
